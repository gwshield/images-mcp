{
  "name": "gwshield-image-builder-mcp",
  "version": "0.3.0",
  "description": "MCP server for AI-assisted hardened Docker image generation following the 15 GWShield hardening pillars",
  "author": "Gatewarden / RelicFrog Foundation",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gwshield-image-builder-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/tests",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwshield/images-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "docker",
    "hardening",
    "container",
    "security",
    "gwshield",
    "gatewarden"
  ]
}
